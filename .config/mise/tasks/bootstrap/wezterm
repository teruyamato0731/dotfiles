#!/usr/bin/env bash
# [MISE] description="Install WezTerm nightly from the official APT repository"
# [MISE] hide=true
set -euo pipefail

readonly package="wezterm-nightly"
readonly key_url="https://apt.fury.io/wez/gpg.key"
readonly keyring="/usr/share/keyrings/wezterm-fury.gpg"
readonly source_list="/etc/apt/sources.list.d/wezterm.list"
readonly repository="deb [signed-by=${keyring}] https://apt.fury.io/wez/ * *"

if dpkg-query -W -f='${db:Status-Status}\n' "${package}" 2>/dev/null |
  grep -qx 'installed'; then
  printf '%s is already installed; skipping.\n' "${package}"
  exit 0
fi

if dpkg-query -W -f='${db:Status-Status}\n' wezterm 2>/dev/null |
  grep -qx 'installed'; then
  printf 'wezterm is already installed and conflicts with %s.\n' "${package}" >&2
  printf 'Remove it first with: sudo apt remove wezterm\n' >&2
  exit 1
fi

tmp_key="$(mktemp)"
trap 'rm -f -- "${tmp_key}"' EXIT

curl -fsSL "${key_url}" |
  gpg --dearmor >"${tmp_key}"

sudo install \
  --owner=root \
  --group=root \
  --mode=0644 \
  "${tmp_key}" \
  "${keyring}"

printf '%s\n' "${repository}" |
  sudo tee "${source_list}" >/dev/null

sudo apt-get update
sudo DEBIAN_FRONTEND=noninteractive apt-get install -y "${package}"
