#!/usr/bin/env bash
# [MISE] description="Install shell completions for mise-managed tools"
# [MISE] hide=true
set -euo pipefail

info() {
  printf '\033[32m[Info] %s:\n  %s\033[m\n' "${MISE_TASK_FILE:-$0}" "$*"
}

warn() {
  printf '\033[33m[Warning] %s:\n  %s\033[m\n' "${MISE_TASK_FILE:-$0}" "$*" >&2
}

install_completion_file() {
  local src="$1"
  local dest="$2"

  if [ -f "${src}" ]; then
    cp -f "${src}" "${dest}"
  else
    warn "Completion file not found: ${src}"
  fi
}

info "Installing shell completions..."
bash_completion_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/bash-completion/completions"
zsh_completion_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/zsh/site-functions"
mkdir -p "${bash_completion_dir}" "${zsh_completion_dir}"

mise completion bash --include-bash-completion-lib > "${bash_completion_dir}/mise"
mise completion zsh > "${zsh_completion_dir}/_mise"

gh_bin="$(mise which gh 2>/dev/null || true)"
if [ -n "${gh_bin}" ]; then
  "${gh_bin}" completion -s bash > "${bash_completion_dir}/gh"
  "${gh_bin}" completion -s zsh > "${zsh_completion_dir}/_gh"
else
  warn "gh is not installed by mise; skipping gh completions."
fi

ghq_bin="$(mise which ghq 2>/dev/null || true)"
if [ -n "${ghq_bin}" ]; then
  ghq_dir="$(dirname "${ghq_bin}")"
  install_completion_file "${ghq_dir}/misc/bash/_ghq" "${bash_completion_dir}/ghq"
  install_completion_file "${ghq_dir}/misc/zsh/_ghq" "${zsh_completion_dir}/_ghq"
else
  warn "ghq is not installed by mise; skipping ghq completions."
fi

bat_bin="$(mise which bat 2>/dev/null || true)"
if [ -n "${bat_bin}" ]; then
  bat_dir="$(dirname "${bat_bin}")"
  install_completion_file "${bat_dir}/autocomplete/bat.bash" "${bash_completion_dir}/bat"
  install_completion_file "${bat_dir}/autocomplete/bat.zsh" "${zsh_completion_dir}/_bat"
else
  warn "bat is not installed by mise; skipping bat completions."
fi

rg_bin="$(mise which rg 2>/dev/null || true)"
if [ -n "${rg_bin}" ]; then
  "${rg_bin}" --generate complete-bash > "${bash_completion_dir}/rg"
  "${rg_bin}" --generate complete-zsh > "${zsh_completion_dir}/_rg"
else
  warn "rg is not installed by mise; skipping rg completions."
fi

fd_bin="$(mise which fd 2>/dev/null || true)"
if [ -n "${fd_bin}" ]; then
  fd_dir="$(dirname "${fd_bin}")"
  install_completion_file "${fd_dir}/autocomplete/fd.bash" "${bash_completion_dir}/fd"
  install_completion_file "${fd_dir}/autocomplete/_fd" "${zsh_completion_dir}/_fd"
else
  warn "fd is not installed by mise; skipping fd completions."
fi

btm_bin="$(mise which btm 2>/dev/null || true)"
if [ -n "${btm_bin}" ]; then
  btm_dir="$(dirname "${btm_bin}")"
  install_completion_file "${btm_dir}/completion/btm.bash" "${bash_completion_dir}/btm"
  install_completion_file "${btm_dir}/completion/_btm" "${zsh_completion_dir}/_btm"
else
  warn "btm is not installed by mise; skipping btm completions."
fi

uv_bin="$(mise which uv 2>/dev/null || true)"
if [ -n "${uv_bin}" ]; then
  "${uv_bin}" generate-shell-completion bash > "${bash_completion_dir}/uv"
  "${uv_bin}" generate-shell-completion zsh > "${zsh_completion_dir}/_uv"
else
  warn "uv is not installed by mise; skipping uv completions."
fi

uvx_bin="$(mise which uvx 2>/dev/null || true)"
if [ -n "${uvx_bin}" ]; then
  "${uvx_bin}" --generate-shell-completion bash > "${bash_completion_dir}/uvx"
  "${uvx_bin}" --generate-shell-completion zsh > "${zsh_completion_dir}/_uvx"
else
  warn "uvx is not installed by mise; skipping uvx completions."
fi

yazi_bin="$(mise which yazi 2>/dev/null || true)"
if [ -n "${yazi_bin}" ]; then
  yazi_dir="$(dirname "${yazi_bin}")"
  install_completion_file "${yazi_dir}/completions/yazi.bash" "${bash_completion_dir}/yazi"
  install_completion_file "${yazi_dir}/completions/ya.bash" "${bash_completion_dir}/ya"
  install_completion_file "${yazi_dir}/completions/_yazi" "${zsh_completion_dir}/_yazi"
  install_completion_file "${yazi_dir}/completions/_ya" "${zsh_completion_dir}/_ya"
else
  warn "yazi is not installed by mise; skipping yazi completions."
fi
